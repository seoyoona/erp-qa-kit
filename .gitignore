!examples/pipe-manufacturing-demo/qa-context/rules/pipe_manufacturing_rules.yaml
!examples/pipe-manufacturing-demo/qa-context/rules/README.md
!examples/pipe-manufacturing-demo/qa-context/feedback/
examples/pipe-manufacturing-demo/qa-context/feedback/*
